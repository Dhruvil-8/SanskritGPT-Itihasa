# HuggingFace upload exclusions
# This file controls what is NOT uploaded to the HuggingFace Hub.

# Git config — no need on HF
.gitignore

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
.venv/
venv/
ENV/
env/

# Jupyter checkpoints and temp files
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
notebooks/temp_corpus*.txt

# Archive notebooks — legacy, not needed
notebooks/archive/

# Documentation drafts — not needed
docs/

# Model zip archive and intermediate checkpoints
model/*.zip
model/**/model_output/
model/Epic/model_output/

# Generated evaluation artifact
evaluation_report.md

# Temp workspace
tmp/

# Logs
*.log

# OS artifacts
.DS_Store
Thumbs.db
